{
  "family": "ml-app-staging",
  "executionRoleArn": "arn:aws:iam::203159929121:role/ml-app-task-execution",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "ml-app",
      "image": "203159929121.dkr.ecr.us-west-2.amazonaws.com/ml-app:latest",
      "essential": true,
      "environment": [
        { "name": "ENVIRONMENT", "value": "staging" }
      ],
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/ml-app-staging",
          "awslogs-region": "us-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
